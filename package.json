    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "got": "^15.0.5",
    "image-js": "^1.6.1",
    "query-string": "^9.4.0",
    "tough-cookie": "^6.0.1",
    "uuid": "^14.0.0",
    "ws": "^8.21.0"
  }
